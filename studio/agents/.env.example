# === fal.ai — pode fazer TUDO (cérebro + pixels) com uma credencial ===
FAL_KEY=

# Cérebro (texto/visão): fal | openai
# fal    -> roda modelos OpenAI/Anthropic/Google via any-llm, com a FAL_KEY.
# openai -> Responses API direto (exige OPENAI_API_KEY).
# Default: fal se houver FAL_KEY, senão openai.
LLM_PROVIDER=fal
FAL_LLM_MODEL=openai/gpt-4o-mini
FAL_VISION_MODEL=openai/gpt-4o

# Como trocar a lata (SWAP_MODE):
# reference -> Agente 3 busca a lata REAL do produto e compõe na mão (embalagem,
#              logo e texto fiéis). Modelo multi-imagem. RECOMENDADO.
# text      -> descreve a marca por texto (o modelo "inventa" a lata; menos fiel).
SWAP_MODE=reference
# Modelo multi-imagem (base + lata real). nano-banana preserva bem o produto.
# Alternativa: fal-ai/flux-pro/kontext/multi
FAL_COMPOSITE_MODEL=fal-ai/gemini-25-flash-image/edit
# Quantas fotos de produto buscar antes de ranquear por visão
PRODUCT_RESEARCH_COUNT=6

# Edição por TEXTO (modo text / fallback): fal | openai
# fal    -> FLUX.1 Kontext (edição por instrução, sem máscara).
# openai -> gpt-image-2 com máscara.
IMAGE_EDIT_PROVIDER=fal
FAL_EDIT_MODEL=fal-ai/flux-pro/kontext

# === OpenAI (OPCIONAL — só se LLM_PROVIDER ou IMAGE_EDIT_PROVIDER = openai) ===
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2

# === Agente 1: origem da foto-base (SOURCING_MODE) ===
# generate  -> gera a base com fal FLUX (lata lisa prata, sem marca). RECOMENDADO.
#              A marca certa é inserida depois pelo Agente 2 (Kontext).
# pinterest -> scrape do Pinterest (precisa de PINTEREST_COOKIE).
SOURCING_MODE=generate
# Modelo de geração da base. Imagen 4 = melhor aderência ao enquadramento.
# Alternativas: fal-ai/flux-pro/v1.1-ultra | fal-ai/bytedance/seedream/v4/text-to-image
FAL_GEN_MODEL=fal-ai/imagen4/preview
# Quantas bases gerar antes de ranquear por visão
SOURCING_GEN_COUNT=4

# === Pinterest (só quando SOURCING_MODE=pinterest) ===
# Cole o cookie do navegador logado (DevTools > Network > request pinterest.com >
# Request Headers > cookie). Sem ele o Pinterest costuma devolver 403.
PINTEREST_COOKIE=
# Domínio regional. Use br para resultados em português.
PINTEREST_TLD=com

# === Ajustes do pipeline ===
# Tamanho do herói gerado (portrait combina com a capa 4:5 do carrossel)
HERO_SIZE=1024x1536
# Quantos candidatos baixar do Pinterest antes de ranquear
SOURCING_CANDIDATES=16
