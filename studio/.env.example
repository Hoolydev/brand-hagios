# Banco — obrigatório
DATABASE_URL=postgresql://user:password@host:5432/hagios?sslmode=require

# Sessão — obrigatório. Gere com: openssl rand -base64 32
AUTH_SECRET=
AUTH_REQUIRED=true

# IA — a mesma FAL_KEY cobre texto e imagem
FAL_KEY=
FAL_LLM_MODEL=anthropic/claude-sonnet-4.5
FAL_IMAGE_MODEL=fal-ai/flux-pro/v1.1-ultra

# Opcional: habilita busca automática na web no Research Agent.
# Sem ela, o dossiê é montado a partir das URLs que o usuário informa.
OPENAI_API_KEY=

# Storage de imagens geradas (opcional)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
